{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "coverageDirectory": "coverage-e2e",
  "moduleNameMapper": {
    "@/entities/(.*)$": "<rootDir>/src/database/entities/$1",
    "@/common/(.*)$": "<rootDir>/src/common/$1",
    "@/config/(.*)$": "<rootDir>/src/config/$1"
  }
}
